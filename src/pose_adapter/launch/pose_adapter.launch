<launch>
  <!-- Pose Adapter - 电表巡检主节点 (ROS2 Humble) -->

  <!-- 相机参数 -->
  <arg name="camera_width" default="1280"/>
  <arg name="camera_height" default="720"/>

  <!-- 是否使用 Go2 相机 SDK 取流（默认 false，从 camera_image_topic 取图，与 calibrate 一致） -->
  <arg name="use_go2_camera" default="false"/>

  <!-- Go2 网络接口：留空则自动检测；eth0 不可用时可用 eth1 -->
  <arg name="network_interface" default="eth1"/>

  <!-- 电表尺寸（米） -->
  <arg name="meter_width" default="0.2"/>   <!-- 电表物理宽度（米）-->
  <arg name="meter_height" default="0.3"/>  <!-- 电表物理高度（米）-->

  <!-- 控制参数 -->
  <arg name="target_distance" default="0.3"/> <!-- 直接控制"离电表多远"，当前逻辑在用 -->
  <arg name="distance_tolerance" default="0.05"/> <!-- 距离容差（米），越小越"抠细节" -->
  <arg name="target_ratio" default="0.5"/> <!-- 画面占比，表示"目标画面占比"，已作为参数传入，但当前控制逻辑里还没参与判断，只占位备用。 -->

  <!-- 低算力：主循环 Hz，默认 5 以降低 CPU（高算力可设 10-20） -->
  <arg name="loop_hz" default="5"/>

  <!-- 模型路径：默认相对工程根目录 model/best.pt -->
  <arg name="yolo_model_path" default="model/best.pt"/>
  <!-- 低算力设备建议 false，PaddleOCR 易引起段错误 -->
  <arg name="use_paddle_ocr" default="false"/>
  <!-- 备用检测时，最小 bbox 面积占比（0-1），默认 0.05 即 5% -->
  <arg name="min_bbox_area_ratio" default="0.05"/>
  <!-- 关键点提取方式: bbox(默认) / contour / keypoint -->
  <arg name="keypoint_method" default="bbox"/>

  <!-- 图像来源：与 calibrate 一致，默认 /camera/image_raw（由其他节点发布相机 raw 图） -->
  <arg name="camera_image_topic" default="/camera/image_raw"/>

  <!-- 标定文件：默认使用工作区中的标定结果 -->
  <arg name="calib_file" default="$(env HOME)/stephen/PoseAdapter/src/calibrate/calibration_results/rtsp_camera_calib.yaml"/>

  <!-- 运动前提：关闭避障 + 经典步态。SDK 支持时启动是否尝试关闭避障 -->
  <arg name="disable_obstacle_avoidance_on_start" default="true"/>
  <!-- 步态：use_classic_walk=true 时稀碎步；false 时用默认步态便于走步。speed_level：-1=慢 0=普通 1=快 -->
  <arg name="use_classic_walk" default="false"/>
  <arg name="speed_level" default="0"/>
  <arg name="max_linear_speed" default="0.2"/>
  <arg name="min_linear_speed" default="0.15"/>
  <arg name="max_angular_speed" default="0.25"/>
  <!-- 步长参数 -->
  <arg name="step_distance" default="0.2"/>  <!-- 每次移动步长（米），默认20cm -->
  <arg name="step_angle" default="5.0"/>     <!-- 每次旋转步长（度），默认5度 -->

  <!-- 机器狗类型: GO2 (Unitree), ZSI-1 (zsibot_sdk)，默认从环境变量 BODY 读取 -->
  <arg name="body_type" default=""/>

  <!-- Pose Adapter 主节点 -->
  <node name="pose_adapter" pkg="pose_adapter" exec="pose_adapter_node.py" output="screen">
    <param name="camera_width" value="$(var camera_width)"/>
    <param name="camera_height" value="$(var camera_height)"/>
    <param name="meter_width" value="$(var meter_width)"/>
    <param name="meter_height" value="$(var meter_height)"/>
    <param name="target_distance" value="$(var target_distance)"/>
    <param name="distance_tolerance" value="$(var distance_tolerance)"/>
    <param name="target_ratio" value="$(var target_ratio)"/>
    <param name="yolo_model_path" value="$(var yolo_model_path)"/>
    <param name="use_paddle_ocr" value="$(var use_paddle_ocr)"/>
    <param name="min_bbox_area_ratio" value="$(var min_bbox_area_ratio)"/>
    <param name="keypoint_method" value="$(var keypoint_method)"/>
    <param name="calib_file" value="$(var calib_file)"/>
    <param name="use_go2_camera" value="$(var use_go2_camera)"/>
    <param name="network_interface" value="$(var network_interface)"/>
    <param name="camera_image_topic" value="$(var camera_image_topic)"/>
    <param name="loop_hz" value="$(var loop_hz)"/>
    <param name="disable_obstacle_avoidance_on_start" value="$(var disable_obstacle_avoidance_on_start)"/>
    <param name="use_classic_walk" value="$(var use_classic_walk)"/>
    <param name="speed_level" value="$(var speed_level)"/>
    <param name="max_linear_speed" value="$(var max_linear_speed)"/>
    <param name="min_linear_speed" value="$(var min_linear_speed)"/>
    <param name="max_angular_speed" value="$(var max_angular_speed)"/>
    <param name="step_distance" value="$(var step_distance)"/>
    <param name="step_angle" value="$(var step_angle)"/>
    <param name="body_type" value="$(var body_type)"/>
  </node>

  <!-- 图像查看（可选，无显示器时需设为 false） -->
  <arg name="show_debug_image" default="false"/>
  <group if="$(var show_debug_image)">
    <node name="image_view" pkg="image_view" exec="image_view" output="screen">
      <remap from="image" to="/pose_adapter/debug_image"/>
    </node>
  </group>

</launch>
